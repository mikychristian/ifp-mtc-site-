<%- include('partials/header', { title, currentPage: 'contact' }) %>

<main class="bg-slate-50">
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="rounded-[2rem] border border-slate-200 bg-slate-950/5 p-10 shadow-sm">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-600">Contactez-nous</p>
          <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Inscription, questions ou visite du campus</h1>
          <p class="mt-6 text-lg leading-8 text-slate-600">Notre équipe est prête à répondre à toutes vos demandes et à vous accompagner dans le choix de votre filière.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-10 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-600">Informations</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900">Contact rapide</h2>
          <p class="mt-4 text-sm leading-6 text-slate-600">Appelez ou écrivez-nous pour toute inscription, demande de dossier ou visite de nos ateliers.</p>
          <div class="mt-8 space-y-6 text-sm text-slate-600">
            <div>
              <p class="font-semibold text-slate-900">Adresse</p>
              <p>Bonabo Garage, Douala</p>
            </div>
            <div>
              <p class="font-semibold text-slate-900">Téléphone</p>
              <p>+237 675 311 138 / +237 641 224 718</p>
            </div>
            <div>
              <p class="font-semibold text-slate-900">Email</p>
              <p>institutfpmtc@gmail.com</p>
            </div>
          </div>
          <a class="mt-8 inline-flex items-center justify-center rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-500/20 transition hover:bg-sky-700" href="https://wa.me/237675311138" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-10 shadow-sm">
          <h2 class="text-3xl font-extrabold text-slate-900">Envoyez-nous un message</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">Nous vous répondrons sous 24h.</p>
          <form class="mt-8 grid gap-4">
            <input type="text" placeholder="Nom complet" class="h-14 rounded-3xl border border-slate-200 bg-slate-50 px-5 text-sm outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100" />
            <input type="email" placeholder="Email" class="h-14 rounded-3xl border border-slate-200 bg-slate-50 px-5 text-sm outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100" />
            <textarea rows="5" placeholder="Votre message..." class="min-h-[160px] rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100"></textarea>
            <button type="button" class="inline-flex h-14 items-center justify-center rounded-full bg-slate-900 px-6 text-sm font-semibold text-white transition hover:bg-slate-800">Envoyer</button>
          </form>
        </div>
      </div>

      <div class="mt-12 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <iframe class="map-frame h-[420px] w-full border-0" src="https://www.google.com/maps?q=Bonabo%20Garage%20Douala&z=14&output=embed" allowfullscreen loading="lazy"></iframe>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
